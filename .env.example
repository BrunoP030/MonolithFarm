# Copie para .env e preencha apenas no ambiente local.
# Nunca versione links privados, cookies, senhas ou hashes reais.

# Pasta local esperada pelo projeto.
MONOLITHFARM_DATA_DIR=data

# URL privada do pacote de dados compactado.
# Preencher no .env local. Não documentar nem commitar o valor real.
MONOLITHFARM_DATA_ARCHIVE_URL=

# Opcional: arquivo de cookies Netscape exportado do navegador para downloads
# privados que exigem sessão autenticada no Google Drive.
MONOLITHFARM_DATA_COOKIE_FILE=

# Opcional: SHA-256 esperado do arquivo baixado.
MONOLITHFARM_DATA_ARCHIVE_SHA256=

# Login local do Data Vault do Atlas.
MONOLITH_ATLAS_USER=monolito_farm
MONOLITH_ATLAS_PASSWORD=
